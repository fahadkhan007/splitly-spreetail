# ================================================================
# Splitly Backend — Environment Variables TEMPLATE
# ================================================================
# This file IS committed to git. It shows every variable the app
# needs, but with no real secrets.
#
# To set up locally:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in real values in .env
# ================================================================

# ── DATABASE ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/spreetail"
ASYNC_DATABASE_URL="postgresql+asyncpg://USER:PASSWORD@localhost:5432/spreetail"

# ── JWT SECURITY ─────────────────────────────────────────────────
SECRET_KEY="generate-with: python -c \"import secrets; print(secrets.token_hex(32))\""
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── EMAIL (RESEND) ───────────────────────────────────────────────
RESEND_API_KEY="re_your_resend_api_key_here"

# ── URLS ─────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
FRANKFURTER_BASE_URL="https://api.frankfurter.app"
